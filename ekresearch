#!/usr/bin/env bash
#
# EK Research CLI — Command wrapper for Golden Standard Research System
#
# Usage:
#   ./ekresearch <command> [query]
#
# Commands:
#   research, r          — Quick research (Tavily + Firecrawl)
#   deepresearch, dr     — Deep research (Full Trinity Stack)
#   twitter, tw          — Twitter/X social research
#   firecrawl, fc       — Firecrawl deep extraction
#   tavily, tv           — Tavily discovery search
#   viral                — Find viral content on X
#   expert               — Expert opinion research
#   design               — Design research (awwwards, dribbble)
#   financial, fin       — Financial research
#   competitive, comp    — Competitive analysis
#   person, p            — Person/influencer research
#   trends               — Current trending topics
#   help, h              — Show this help message
#
# Examples:
#   ./ekresearch research "GPT Image 2.0"
#   ./ekresearch deepresearch "Bitcoin DeFi protocols 2026"
#   ./ekresearch twitter "AI agents min_retweets:20"
#   ./ekresearch viral "OpenAI"
#   ./ekresearch design "dark mode design system"
#   ./ekresearch financial "NVDA earnings"

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESEARCH_DIR="${SCRIPT_DIR}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Header
show_header() {
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║              🏆 EK Research — Golden Standard                ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Help
show_help() {
    show_header
    echo -e "${GREEN}Usage:${NC} ekresearch ${YELLOW}<command>${NC} [query/options]"
    echo ""
    echo -e "${GREEN}Research Commands:${NC}"
    echo "  ${YELLOW}research, r${NC} <query>       — Quick research (Tavily + Firecrawl)"
    echo "  ${YELLOW}deepresearch, dr${NC} <query>  — Deep research (Full Trinity Stack + analysis)"
    echo "  ${YELLOW}quick, q${NC} <query>          — Fast research (Tavily only)"
    echo ""
    echo -e "${GREEN}Source-Specific Commands:${NC}"
    echo "  ${YELLOW}twitter, tw${NC} <query>       — X/Twitter social research"
    echo "  ${YELLOW}firecrawl, fc${NC} <url>       — Deep scrape a specific URL"
    echo "  ${YELLOW}tavily, tv${NC} <query>        — Tavily AI search"
    echo ""
    echo -e "${GREEN}Specialized Research:${NC}"
    echo "  ${YELLOW}viral${NC} <topic>             — Find viral content on X"
    echo "  ${YELLOW}expert${NC} <topic>            — Expert opinions and threads"
    echo "  ${YELLOW}design${NC} <query>            — Design research (awwwards, trends)"
    echo "  ${YELLOW}financial, fin${NC} <ticker>   — Financial research (stocks, crypto)"
    echo "  ${YELLOW}competitive, comp${NC} <query> — Competitive analysis"
    echo "  ${YELLOW}person, p${NC} <username>      — Person/influencer research"
    echo "  ${YELLOW}trends${NC}                    — Current trending topics"
    echo ""
    echo -e "${GREEN}Utility:${NC}"
    echo "  ${YELLOW}help, h${NC}                   — Show this help"
    echo "  ${YELLOW}test${NC}                      — Test all API connections"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ekresearch research \"GPT Image 2.0 features\""
    echo "  ekresearch deepresearch \"Bitcoin DeFi protocols 2026\""
    echo "  ekresearch viral \"OpenAI\""
    echo "  ekresearch expert \"GPT 5.5 performance benchmark\""
    echo "  ekresearch design \"dark mode glassmorphism 2026\""
    echo "  ekresearch financial \"NVDA earnings Q2 2026\""
    echo "  ekresearch person elonmusk"
    echo "  ekresearch trends"
    echo ""
    echo -e "${GREEN}Pro Tips:${NC}"
    echo "  • Use quotes for multi-word queries"
    echo "  • Add 'min_retweets:N' for quality filtering"
    echo "  • Deep research runs all 3 engines + synthesis"
}

# Test API connections
test_apis() {
    show_header
    echo -e "${CYAN}Testing API connections...${NC}"
    echo ""
    
    # Test Tavily
    echo -n "🔍 Tavily: "
    if node -e "
        fetch('https://api.tavily.com/search', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                api_key: '${TAVILY_API_KEY}',
                query: 'test',
                search_depth: 'basic',
                max_results: 1
            })
        }).then(r => r.ok ? console.log('✅ OK') : console.log('❌ Failed')).catch(e => console.log('❌ Error'))
    " 2>/dev/null | grep -q "OK"; then
        echo -e "${GREEN}✅ Connected${NC}"
    else
        echo -e "${RED}❌ Failed${NC}"
    fi
    
    # Test Firecrawl
    echo -n "🔥 Firecrawl: "
    if node -e "
        fetch('https://api.firecrawl.dev/v1/scrape', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ${FIRECRAWL_API_KEY}'
            },
            body: JSON.stringify({
                url: 'https://example.com',
                formats: ['markdown']
            })
        }).then(r => r.ok || r.status === 400 ? console.log('✅ OK') : console.log('❌ Failed')).catch(e => console.log('❌ Error'))
    " 2>/dev/null | grep -q "OK"; then
        echo -e "${GREEN}✅ Connected${NC}"
    else
        echo -e "${RED}❌ Failed${NC}"
    fi
    
    # Test TwitterAPI.io
    echo -n "🐦 TwitterAPI.io: "
    if node -e "
        fetch('https://api.twitterapi.io/twitter/tweet/advanced_search?query=test&queryType=Latest', {
            headers: {'x-api-key': '${TWITTERAPI_IO_KEY}'}
        }).then(r => r.ok ? console.log('✅ OK') : console.log('❌ Failed')).catch(e => console.log('❌ Error'))
    " 2>/dev/null | grep -q "OK"; then
        echo -e "${GREEN}✅ Connected${NC}"
    else
        echo -e "${RED}❌ Failed${NC}"
    fi
    
    echo ""
    echo -e "${CYAN}Test complete!${NC}"
}

# Main command handler
main() {
    local cmd="$1"
    shift || true
    local query="$*"
    
    case "$cmd" in
        research|r)
            show_header
            echo -e "${CYAN}🔍 Quick Research: ${YELLOW}$query${NC}"
            echo ""
            node "${RESEARCH_DIR}/scripts/unified-research.mjs" "$query"
            ;;
            
        deepresearch|dr)
            show_header
            echo -e "${CYAN}🏆 Deep Research (Full Trinity Stack): ${YELLOW}$query${NC}"
            echo ""
            # Run unified research with enhanced options
            TWITTER_MIN_RETWEETS=10 TWITTER_MIN_LIKES=50 \
                node "${RESEARCH_DIR}/scripts/unified-research.mjs" "$query"
            ;;
            
        quick|q)
            show_header
            echo -e "${CYAN}⚡ Quick Search: ${YELLOW}$query${NC}"
            echo ""
            node -e "
                const key = '${TAVILY_API_KEY}';
                fetch('https://api.tavily.com/search', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        api_key: key,
                        query: '$query',
                        search_depth: 'advanced',
                        include_answer: true,
                        max_results: 5
                    })
                }).then(r => r.json()).then(d => {
                    console.log('🤖 AI Summary:', d.answer || 'N/A');
                    console.log('');
                    console.log('📚 Sources:');
                    (d.results || []).forEach((r, i) => {
                        console.log(\`  \${i+1}. \${r.title}\`);
                        console.log(\`     \${r.url}\`);
                    });
                });
            "
            ;;
            
        twitter|tw)
            show_header
            echo -e "${CYAN}🐦 Twitter/X Research: ${YELLOW}$query${NC}"
            echo ""
            node "${RESEARCH_DIR}/scripts/twitterapi-client.mjs" search "$query"
            ;;
            
        firecrawl|fc)
            show_header
            echo -e "${CYAN}🔥 Firecrawl Deep Extraction: ${YELLOW}$query${NC}"
            echo ""
            if [[ "$query" == http* ]]; then
                node -e "
                    const key = '${FIRECRAWL_API_KEY}';
                    fetch('https://api.firecrawl.dev/v1/scrape', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': 'Bearer ' + key
                        },
                        body: JSON.stringify({
                            url: '$query',
                            formats: ['markdown'],
                            onlyMainContent: true
                        })
                    }).then(r => r.json()).then(d => {
                        if (d.success) {
                            console.log('📄 Title:', d.data.metadata?.title || 'N/A');
                            console.log('');
                            console.log(d.data.markdown?.slice(0, 3000) || 'No content');
                        } else {
                            console.log('❌ Error:', d.error);
                        }
                    });
                "
            else
                echo -e "${RED}Error: Please provide a URL starting with http:// or https://${NC}"
                exit 1
            fi
            ;;
            
        tavily|tv)
            show_header
            echo -e "${CYAN}🔍 Tavily Discovery: ${YELLOW}$query${NC}"
            echo ""
            node -e "
                const key = '${TAVILY_API_KEY}';
                fetch('https://api.tavily.com/search', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        api_key: key,
                        query: '$query',
                        search_depth: 'advanced',
                        include_answer: true,
                        max_results: 10
                    })
                }).then(r => r.json()).then(d => {
                    console.log('🤖 AI Summary:', d.answer || 'N/A');
                    console.log('');
                    console.log('📚 Sources:');
                    (d.results || []).forEach((r, i) => {
                        console.log(\`  \${i+1}. \${r.title}\`);
                        console.log(\`     \${r.url}\`);
                        console.log(\`     \${r.content?.slice(0, 150)}...\`);
                        console.log('');
                    });
                });
            "
            ;;
            
        viral)
            show_header
            echo -e "${CYAN}🔥 Viral Content Search: ${YELLOW}$query${NC}"
            echo ""
            node "${RESEARCH_DIR}/scripts/twitterapi-client.mjs" search "$query min_retweets:50"
            ;;
            
        expert)
            show_header
            echo -e "${CYAN}👨‍🔬 Expert Opinion Research: ${YELLOW}$query${NC}"
            echo ""
            # Search for expert threads with high engagement
            node "${RESEARCH_DIR}/scripts/twitterapi-client.mjs" search "$query min_retweets:20 min_likes:100"
            ;;
            
        design)
            show_header
            echo -e "${CYAN}🎨 Design Research: ${YELLOW}$query${NC}"
            echo ""
            # Enhanced design query with design-specific terms
            DESIGN_QUERY="$query awwwards dribbble design system"
            node "${RESEARCH_DIR}/scripts/unified-research.mjs" "$DESIGN_QUERY"
            ;;
            
        financial|fin)
            show_header
            echo -e "${CYAN}💰 Financial Research: ${YELLOW}$query${NC}"
            echo ""
            # Enhanced financial query
            FIN_QUERY="$query earnings analyst price target 2026"
            node "${RESEARCH_DIR}/scripts/unified-research.mjs" "$FIN_QUERY"
            ;;
            
        competitive|comp)
            show_header
            echo -e "${CYAN}⚔️ Competitive Analysis: ${YELLOW}$query${NC}"
            echo ""
            # Enhanced competitive query
            COMP_QUERY="$query comparison vs alternative 2026 review"
            node "${RESEARCH_DIR}/scripts/unified-research.mjs" "$COMP_QUERY"
            ;;
            
        person|p)
            show_header
            echo -e "${CYAN}👤 Person Research: ${YELLOW}$query${NC}"
            echo ""
            if [[ "$query" != http* ]]; then
                # Treat as username
                node "${RESEARCH_DIR}/scripts/twitterapi-client.mjs" user "$query"
            else
                node "${RESEARCH_DIR}/scripts/unified-research.mjs" "$query background expertise"
            fi
            ;;
            
        trends)
            show_header
            echo -e "${CYAN}🔥 Current Trending Topics${NC}"
            echo ""
            node "${RESEARCH_DIR}/scripts/twitterapi-client.mjs" trends
            ;;
            
        test)
            test_apis
            ;;
            
        help|h|""|*)
            show_help
            ;;
    esac
}

# Load environment variables from .env if present
if [ -f "${RESEARCH_DIR}/.env" ]; then
    export $(grep -v '^#' "${RESEARCH_DIR}/.env" | xargs)
fi

# Run main
main "$@"
